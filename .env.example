# Database (Prisma Postgres recommended)
# Use your pooled connection string here for DATABASE_URL.
# Get a separate direct connection string from the Prisma dashboard and use it for DIRECT_URL (better for migrations).
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...   # often the same or a "direct" variant

# NextAuth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/auth/clients
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional
VOYAGE_API_KEY=

# Encryption (CRITICAL for prod): 32+ random bytes hex. All-zero or example values will expose all memories.
# Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=REDACTED_MASTER_KEY_32BYTES00000000000000000000000000000000
NODE_ENV=development
