# Unimatrix Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS Region for all services (Cognito, RDS, AppSync, Lambda, S3)
AWS_REGION=us-east-1

# AWS Account ID (found in AWS Console)
AWS_ACCOUNT_ID=123456789012

# AWS Access Key ID (for AWS CDK deployment)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY

# AWS Secret Access Key (for AWS CDK deployment)
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# ============================================================================
# Cognito Configuration
# ============================================================================

# Cognito User Pool ID (created by CDK, found in CloudFormation outputs)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# Cognito User Pool Web Client ID (created by CDK)
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx

# Cognito Identity Pool ID (for AWS credentials)
COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================================
# AppSync GraphQL API
# ============================================================================

# AppSync GraphQL API Endpoint (created by CDK)
APPSYNC_GRAPHQL_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.appsync-api.us-east-1.amazonaws.com/graphql

# AppSync GraphQL API Key (for unauthenticated access, optional)
APPSYNC_API_KEY=da2-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Model (default: claude-3-opus-20240229)
# Available: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
CLAUDE_MODEL=claude-3-opus-20240229

# ============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Model (default: gpt-4-turbo-preview)
# Available: gpt-4, gpt-4-turbo-preview, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================================================

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini Model (default: gemini-pro)
# Available: gemini-pro, gemini-pro-vision, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-pro

# ============================================================================

# Groq API Key (ultra-fast inference)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq Model (default: mixtral-8x7b-32768)
# Available: mixtral-8x7b-32768, llama2-70b-4096, llama3-70b-8192, llama3-8b-8192
GROQ_MODEL=mixtral-8x7b-32768

# ============================================================================

# Ollama Configuration (local LLM)
# Ollama endpoint (default: http://localhost:11434)
OLLAMA_ENDPOINT=http://localhost:11434

# Ollama Model (default: mistral)
# Available: mistral, llama2, neural-chat, dolphin-mixtral, etc.
OLLAMA_MODEL=mistral

# ============================================================================
# Database Configuration
# ============================================================================

# RDS PostgreSQL Database Host
# Format: your-db-instance.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_HOST=your-db-instance.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com

# RDS Database Port (default: 5432)
RDS_PORT=5432

# RDS Database Name (default: unimatrix)
RDS_DATABASE=unimatrix

# RDS Master Username (default: admin)
RDS_USERNAME=admin

# RDS Master Password
RDS_PASSWORD=YourSecurePasswordHere

# ============================================================================
# ElastiCache Redis Configuration
# ============================================================================

# Redis Endpoint
# Format: your-redis-cluster.xxxxxxxxxxxx.ng.0001.use1.cache.amazonaws.com:6379
REDIS_ENDPOINT=your-redis-cluster.xxxxxxxxxxxx.ng.0001.use1.cache.amazonaws.com

# Redis Port (default: 6379)
REDIS_PORT=6379

# Redis Password (if enabled)
REDIS_PASSWORD=YourRedisPasswordHere

# ============================================================================
# Application Configuration
# ============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application Port (for web/API server)
PORT=3000

# Domain Name
DOMAIN_NAME=unimatrix.app

# Frontend URL (for CORS, redirects, etc.)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Billing & Monitoring
# ============================================================================

# Stripe API Keys (for payment processing)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry DSN (for error tracking)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxxx

# ============================================================================
# Mobile App Configuration
# ============================================================================

# Expo Configuration
EXPO_OWNER=your-expo-username
EXPO_PROJECT_NAME=unimatrix

# ============================================================================
# Logging & Debugging
# ============================================================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Enable verbose logging for development
DEBUG=unimatrix:*

# ============================================================================
# Security
# ============================================================================

# JWT Secret (for session tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Encryption Key (for sensitive data)
ENCRYPTION_KEY=your-encryption-key-32-characters-long

# ============================================================================
