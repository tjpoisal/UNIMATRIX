# ============================================================================
# SEE ACCOUNTS_AND_SECRETS.md FOR THE COMPLETE LIST
# ============================================================================
# - Every account/service you need to sign up for (Fly.io, Neon, Clerk, Stripe, Resend, Voyage, Ably, Upstash, Google, GitHub, Expo).
# - Exact mapping of every secret in your .env list to how to obtain it.
# - Best services recommendations for optimal Unimatrix on Fly.io.
# - Generation commands for local secrets.
# This is the single source of truth.

# Quick template below (fill from the accounts doc + your dashboards).

# Database (Neon - best: serverless Postgres + pgvector)
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...   # direct for migrations

# Suppress Prisma marketing (we use free OSS only — no signup/Accelerate needed)
PRISMA_HIDE_UPDATE_MESSAGE=true
PRISMA_TELEMETRY_INFORMATION=false

# NextAuth v5 (web)
AUTH_SECRET=   # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=   # openssl rand -base64 32
AUTH_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Clerk (MCP server auth + tokens)
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe (payments + prices — create via dashboard or scripts/setup-stripe.js)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Unimatrix <onboarding@resend.dev>

# Embeddings (Voyage AI - best specialized)
VOYAGE_API_KEY=

# Encryption (generate locally)
MASTER_ENCRYPTION_KEY=   # openssl rand -hex 32

# Realtime best (Ably for Collab; Upstash for Redis)
ABLY_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Mobile
EXPO_TOKEN=   # for EAS builds (expo.dev)
EXPO_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime
NODE_ENV=development

# Cron protection (generate locally)
CRON_SECRET=   # openssl rand -base64 32

# After Fly deploy: override URLs + set all as `fly secrets set KEY=val --app <app>`
# See DEPLOYMENT.md + ACCOUNTS_AND_SECRETS.md for the full best-services setup.

# Encryption (CRITICAL for prod): 32+ random bytes hex. All-zero or example values will expose all memories.
# Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=REDACTED_MASTER_KEY_32BYTES00000000000000000000000000000000
NODE_ENV=development
