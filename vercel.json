{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm turbo run build --filter=web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/reset-spend",
      "schedule": "0 0 * * *"
    }
    // Note: "expire-pending" cron removed because Hobby accounts only allow 1 cron run per day.
    // Expiry now happens automatically on read in the pending-actions endpoint.
  ]
}
