# Multi-stage Dockerfile for the Unimatrix Web Portal + Collab WS Server
# Uses custom server.ts for persistent WebSocket support (Collab Room)

FROM node:20-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app

# Root workspace manifests
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/
COPY apps/web/prisma ./apps/web/prisma

# Install dependencies for web workspace
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --filter web --frozen-lockfile

# Copy source (full packages for workspace deps like @unimatrix/db)
COPY apps/web ./apps/web
COPY packages ./packages

# Install db package deps (for prisma cli in its build)
RUN pnpm install --filter @unimatrix/db --frozen-lockfile

# Build shared @unimatrix/db first (monorepo workspace dep for future unification / bridge)
WORKDIR /app/packages/db
RUN pnpm build

WORKDIR /app/apps/web

# Generate Prisma (web's local schema) + build Next.js + custom server
RUN pnpm prisma generate
RUN pnpm build

# --- Production runner ---
FROM node:20-slim AS production

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app

ENV NODE_ENV=production
# PORT matches the internal_port and [env] in fly.web.toml (Fly routes to it)
ENV PORT=8080

# Copy manifests for a prod-only install in this stage (to get clean node_modules without pnpm virtual store symlink issues from base layers)
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/
COPY apps/web/prisma ./apps/web/prisma
COPY packages/db/package.json ./packages/db/

# Prod install for web to get self-contained node_modules with 'next', 'ws' etc (ignore scripts to avoid prisma CLI which isn't in --prod)
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --filter web --prod --frozen-lockfile --ignore-scripts --shamefully-hoist

# Copy only what is needed at runtime (built artifacts)
COPY --from=base /app/apps/web/.next ./.next
COPY --from=base /app/apps/web/dist ./dist
COPY --from=base /app/apps/web/public ./public
COPY --from=base /app/apps/web/package.json ./
COPY --from=base /app/apps/web/prisma ./prisma

# Ensure @unimatrix/db built output + its isolated generated client (rich models) are present
COPY --from=base /app/packages/db/dist /app/packages/db/dist
COPY --from=base /app/packages/db/generated /app/packages/db/generated
COPY --from=base /app/packages/db/package.json /app/packages/db/package.json

# Copy server.ts compiled output (dist/server.js)
# Also bring in any runtime config
COPY --from=base /app/apps/web/next.config.ts ./

EXPOSE 8080

# Healthcheck
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD node -e "require('http').get('http://localhost:8080/api/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

# Run the custom server (Next.js + WebSocket)
# PORT handled via env from fly.toml (8080)
CMD ["node", "dist/server.js"]
