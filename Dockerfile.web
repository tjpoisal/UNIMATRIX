# Dockerfile for Unimatrix Web (Next.js)
# Standard Next.js deployment on Fly.io

FROM node:20-slim AS base

# Install dependencies needed for Prisma
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
      openssl \
      libssl-dev \
      ca-certificates \
      curl \
    && rm -rf /var/lib/apt/lists/*

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

# Copy package files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY apps/web/package.json ./apps/web/
COPY apps/web/prisma ./apps/web/prisma

# Install dependencies
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --filter web --frozen-lockfile

# Copy source files
COPY apps/web ./apps/web
COPY packages ./packages
COPY tsconfig.json ./

# Build the app
WORKDIR /app/apps/web
RUN pnpm prisma generate
RUN pnpm build

# Production stage
FROM node:20-slim AS production

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV NODE_ENV=production
ENV PORT=8080

RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
      openssl \
      libssl-dev \
      ca-certificates \
      curl \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /app

# Copy package files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY apps/web/package.json ./apps/web/
COPY apps/web/prisma ./apps/web/prisma

# Install production dependencies
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --filter web --prod --frozen-lockfile --ignore-scripts

# Copy built artifacts
COPY --from=base /app/apps/web/.next ./.next
COPY --from=base /app/apps/web/public ./public
COPY --from=base /app/apps/web/prisma ./prisma

EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -sf http://localhost:8080/api/health || exit 1

# Start Next.js
CMD ["pnpm", "start"]
