{
  "name": "unimatrix",
  "version": "0.1.0",
  "description": "Memory Palace for LLMs via MCP",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql && psql $DATABASE_URL -f migrations/002_indexes_security.sql && psql $DATABASE_URL -f migrations/003_space_embeddings.sql"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.7",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@prisma/client": "^6.19.3",
    "@types/pg": "^8.11.0",
    "fastify": "^5.0.0",
    "pg": "^8.21.0",
    "pgvector": "^0.2.1",
    "prisma": "^6.19.3",
    "svix": "^1.93.0",
    "voyageai": "^0.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
