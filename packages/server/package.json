{
  "name": "@unimatrix/server",
  "version": "0.1.0",
  "description": "UniMatrix backend server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && echo 'Build complete (includes worker.ts)'",
    "start": "node dist/index.js",
    "migrate:sqlite-to-neon": "tsx scripts/migrate-sqlite-to-neon.ts",
    "migrate:sqlite-to-neon:dry": "tsx scripts/migrate-sqlite-to-neon.ts --dry-run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.3.0",
    "@unimatrix/db": "workspace:*",
    "@unimatrix/types": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^26.0.0",
    "typescript": "^5.9.3",
    "tsx": "^4.7.0"
  }
}
