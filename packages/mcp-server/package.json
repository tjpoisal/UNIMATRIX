{
  "name": "@unimatrix/mcp-server",
  "version": "1.0.0",
  "description": "MCP server bridge for Unimatrix. Connect Claude Desktop, Cursor, Windsurf, Ollama, and any Model Context Protocol client to persistent, hierarchical memory palaces.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "unimatrix-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tjpoisal/UNIMATRIX.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://deployunimatrix.com",
  "bugs": {
    "url": "https://github.com/tjpoisal/UNIMATRIX/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "memory-palace",
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "unimatrix"
  ],
  "author": "Unimatrix",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
