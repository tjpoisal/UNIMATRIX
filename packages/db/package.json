{
  "name": "@unimatrix/db",
  "version": "0.1.0",
  "description": "Shared Prisma client and database types for Unimatrix (source of truth schema)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "postinstall": "PRISMA_HIDE_UPDATE_MESSAGE=true prisma generate",
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
