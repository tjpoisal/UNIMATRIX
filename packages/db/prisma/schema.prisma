generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"  // local output (package root) to avoid clobbering shared @prisma/client used by web's legacy schema; copied/bundled for consumers
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum MemoryStatus {
  active
  superseded
  archived
}

enum MemorySource {
  mcp
  api
  import
  librarian
}

enum AgentRunStatus {
  pending
  running
  completed
  failed
}

enum TokenScope {
  full
  readonly
  memory_only
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  clerk_id         String    @unique
  email            String    @unique
  name             String?
  image            String?
  tier             String    @default("free") // free | pro | team
  stripeCustomerId String?   @unique

  // Relations
  spaces     Space[]
  memories   Memory[]
  memoryShares MemoryShare[] @relation("MemoryShareRecipient")
  mcpTokens  McpToken[]
  agentRuns  AgentRun[]
  stripeSubscriptions StripeSubscription[]
  auditLogs  AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([clerk_id])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// Space (hierarchical — replaces Palace/Location)
// ─────────────────────────────────────────────────────────────────────────────

model Space {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId      String?
  parent        Space?    @relation("NestedSpaces", fields: [parentId], references: [id], onDelete: Cascade)
  children      Space[]   @relation("NestedSpaces")

  orgId         String?
  name          String
  description   String?
  isScratchpad  Boolean   @default(false)
  embedding     Bytes?

  // Relations
  memories      Memory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // soft delete

  @@index([userId])
  @@index([parentId])
  @@map("spaces")
}

// ─────────────────────────────────────────────────────────────────────────────
// Memory
// ─────────────────────────────────────────────────────────────────────────────

model Memory {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  spaceId       String?      @map("space_id") @db.Uuid
  space         Space?       @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  orgId         String?      @map("org_id") @db.Uuid

  content       Bytes
  contentIv     Bytes        @map("content_iv")

  summary       String?
  embedding     Bytes?

  status        MemoryStatus @default(active)
  supersededBy  String?      @map("superseded_by") @db.Uuid
  supersededAt  DateTime?    @map("superseded_at")

  confidence    Float        @default(0.5)
  mentionCount  Int          @default(1) @map("mention_count")
  source        MemorySource @default(mcp)
  hint          String?

  indexedAt     DateTime?    @map("indexed_at")
  expiresAt     DateTime?    @map("expires_at")   // TTL — null = never expires

  // Relations
  tags          MemoryTag[]
  shares        MemoryShare[]
  linksA        MemoryLink[] @relation("MemoryLinkA")
  linksB        MemoryLink[] @relation("MemoryLinkB")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt     @map("updated_at")
  deletedAt     DateTime?                      @map("deleted_at")

  @@index([userId])
  @@index([spaceId])
  @@index([status])
  @@index([indexedAt])
  @@index([expiresAt])
  @@map("memories")
}

// ─────────────────────────────────────────────────────────────────────────────
// MemoryTag (upsert pattern — unique per memory+tag)
// ─────────────────────────────────────────────────────────────────────────────

model MemoryTag {
  id        String   @id @default(cuid())
  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  tag       String

  createdAt DateTime @default(now())

  @@unique([memoryId, tag])
  @@index([memoryId])
  @@index([tag])
  @@map("memory_tags")
}

// ─────────────────────────────────────────────────────────────────────────────
// McpToken
// ─────────────────────────────────────────────────────────────────────────────

model McpToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String?   @unique // raw token (or public id) — unique; nullable per security (only hash stored)
  hashedToken  String    @map("hashed_token") // bcrypt hash for validation

  scope        TokenScope @default(full)
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@index([token])
  @@map("mcp_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// AgentRun
// ─────────────────────────────────────────────────────────────────────────────

model AgentRun {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  task         String
  status       AgentRunStatus @default(pending)
  errorMsg     String?

  llmProvider  String?
  model        String?
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?           @map("latency_ms")
  costUsd      Decimal?       @db.Decimal(10, 6) @map("cost_usd")

  result       Json?
  memoryIds    String[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("agent_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String   // CREATE, READ, DELETE, SUPERSEDE, EXPORT, SHARE
  memoryId  String?  @map("memory_id") @db.Uuid
  memory    Memory?  @relation(fields: [memoryId], references: [id], onDelete: SetNull)
  resource  String?  // affected resource type
  resourceId String? // affected resource id
  metadata  Json?    // extra context

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model MemoryShare {
  id           String   @id @default(cuid())
  memoryId     String   @map("memory_id") @db.Uuid
  sharedWithId String   @map("shared_with_id")
  canRead      Boolean  @default(true) @map("can_read")
  canDelete    Boolean  @default(false) @map("can_delete")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  memory       Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  sharedWith   User     @relation("MemoryShareRecipient", fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([sharedWithId])
  @@map("memory_shares")
}

model MemoryLink {
  id        String   @id @default(cuid())
  memoryAId String   @map("memory_a_id") @db.Uuid
  memoryBId String   @map("memory_b_id") @db.Uuid
  linkType  String   @default("entity_shared") @map("link_type")
  weight    Float    @default(1.0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memoryA   Memory   @relation("MemoryLinkA", fields: [memoryAId], references: [id], onDelete: Cascade)
  memoryB   Memory   @relation("MemoryLinkB", fields: [memoryBId], references: [id], onDelete: Cascade)

  @@unique([memoryAId, memoryBId])
  @@index([memoryAId])
  @@index([memoryBId])
  @@map("memory_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stripe Subscriptions (canonical)
// ─────────────────────────────────────────────────────────────────────────────

model StripeSubscription {
  id                   String   @id @default(cuid())
  userId               String?  @db.Uuid
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String   @unique
  stripeSubscriptionId String   @unique
  status               String
  priceId              String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAt             DateTime?
  cancelledAt          DateTime?
  metadata             Json?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@map("stripe_subscriptions")
}
