generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User accounts
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?   // nullable for OAuth users
  name      String?
  image     String?   // profile image from OAuth
  tier                 String    @default("free") // free | pro
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?

  // Relations
  accounts      Account[]
  palaces       Palace[]
  sessions      Session[]
  apiKeys       ApiKey[]
  llmProviders  LLMProvider[]
  agentRuns     AgentRun[]

  // Social
  friendRequestsSent     Friendship[]  @relation("FriendRequests")
  friendRequestsReceived Friendship[]  @relation("FriendAddressees")
  palacesSharedByMe      PalaceShare[] @relation("SharedByUser")
  palacesSharedWithMe    PalaceShare[] @relation("SharedWithUser")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([email])
  @@index([tier])
}

// OAuth accounts linked to users
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Memory Palaces
model Palace {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isPublic    Boolean   @default(false)

  locations   Location[]
  shares      PalaceShare[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // soft delete

  @@unique([userId, name])
  @@index([userId])
  @@index([createdAt])
}

// Locations (hierarchical folders within palaces)
model Location {
  id        String    @id @default(cuid())
  palaceId  String
  palace    Palace    @relation(fields: [palaceId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    Location? @relation("NestedLocations", fields: [parentId], references: [id], onDelete: Cascade)
  children  Location[] @relation("NestedLocations")

  name        String
  description String?
  position    Int     @default(0)

  memories  Memory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@unique([palaceId, parentId, name])
  @@index([palaceId])
  @@index([parentId])
  @@index([position])
}

// Memories stored in locations
model Memory {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  content     String
  tags        String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastAccessed DateTime @default(now())
  deletedAt    DateTime? // soft delete

  @@index([locationId])
  @@index([tags])
}

// Sync state for offline-first mobile app
model SyncState {
  id          String    @id @default(cuid())
  userId      String
  deviceId    String
  deviceName  String?

  lastSync       DateTime @default(now())
  pendingChanges Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, deviceId])
  @@index([userId])
}

// Sessions for auth (NextAuth)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

// Verification tokens (email verification, password reset)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([identifier])
}

// API keys for LLM/MCP integrations
model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String    // e.g. "Claude Desktop", "My ChatGPT Key"
  keyHash   String    @unique  // bcrypt hash of the actual key
  keyPrefix String    // first 8 chars shown in UI e.g. "umx_a1b2"
  lastUsed  DateTime?

  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([keyHash])
}

// User-connected LLM providers (encrypted API keys)
model LLMProvider {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider     String   // claude | openai | gemini | groq | ollama
  model        String   // e.g. "claude-opus-4-6", "gpt-4o", "gemini-pro"
  label        String?  // user-friendly name e.g. "My Claude Key"
  keyEncrypted String   // AES-256-GCM encrypted API key
  keyIv        String   // initialization vector for decryption
  keyPrefix    String   // first 8 chars for display
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([provider])
  @@unique([userId, provider, model])
}

// Collaborative agent run sessions
model AgentRun {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  task      String   // the question or task submitted
  mode      String   @default("parallel") // parallel | sequential | debate
  providers String[] // provider names that participated

  result      Json?    // final synthesized result { synthesis, responses[] }
  memoryIds   String[] // IDs of Memory records created from this run
  palaceId    String?  // palace where memories were saved

  status    String   @default("pending") // pending | running | complete | error
  errorMsg  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Friend connections between users
model Friendship {
  id          String   @id @default(cuid())

  requesterId String
  requester   User     @relation("FriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  addresseeId String
  addressee   User     @relation("FriendAddressees", fields: [addresseeId], references: [id], onDelete: Cascade)

  status      String   @default("pending") // pending | accepted | blocked

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

// Palace sharing with specific users and permission levels
model PalaceShare {
  id           String   @id @default(cuid())

  palaceId     String
  palace       Palace   @relation(fields: [palaceId], references: [id], onDelete: Cascade)

  sharedById   String
  sharedBy     User     @relation("SharedByUser", fields: [sharedById], references: [id], onDelete: Cascade)

  sharedWithId String
  sharedWith   User     @relation("SharedWithUser", fields: [sharedWithId], references: [id], onDelete: Cascade)

  permission   String   @default("view") // view | edit

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([palaceId, sharedWithId])
  @@index([palaceId])
  @@index([sharedById])
  @@index([sharedWithId])
}
