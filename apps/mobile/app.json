{
  "expo": {
    "name": "Unimatrix",
    "slug": "unimatrix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.unimatrix.app"
    },
    "android": {
      "package": "app.unimatrix.app",
      "supportsTabletMode": true,
      "bundleIdentifier": "com.getstackmax.unimatrix",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.getstackmax.unimatrix",
      "versionCode": 1,
      "adaptiveIcon": {
        "foreground": "./assets/images/android-icon-foreground.png",
        "background": "./assets/images/android-icon-background.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardAtBack": true
          }
        }
      ]
    ],
    "schemes": ["myapp"],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c3f8a2b1-9d4e-4f5a-b6c7-d8e9f0a1b2c3"
      }
    }
    "plugins": [],
    "scheme": "unimatrix",
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "your-eas-project-id" },
      "apiUrl": "https://deployunimatrix.com"
    },
    "owner": "tjpoisal"
  }
}
