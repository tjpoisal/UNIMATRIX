{
  "expo": {
    "name": "Unimatrix",
    "slug": "unimatrix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.getstackmax.unimatrix",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.getstackmax.unimatrix",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F1C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "scheme": "unimatrix",
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "your-eas-project-id" },
      "apiUrl": "https://deployunimatrix.com"
    },
    "owner": "tjpoisal"
  }
}
