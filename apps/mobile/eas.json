{
  "cli": {
    "version": "20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unimatrix-web.fly.dev/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unimatrix-web.fly.dev/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "tim@getstackmax.com",
        "ascAppId": "6748523981",
        "appleTeamId": "TEAM_ID_PLACEHOLDER"  // TODO: replace with your 10-char Apple Team ID (e.g. from https://developer.apple.com/account/#/membership or eas configure output)
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "production"
      }
    }
  }
}
