{
  // EAS Build config for Unimatrix mobile (Expo).
  // IMPORTANT for iOS: Real device builds, distribution, and App Store submission require a paid Apple Developer Program membership ($99 USD / year).
  // User currently cannot afford this fee. Therefore:
  // - Use "preview" profile for iOS (simulator builds only - free).
  // - Android production builds work fine (no Apple fee).
  // - iOS production/submit sections are placeholders and will fail until membership + credentials are obtained.
  // Run from monorepo root: pnpm mobile:build:android (or :ios for simulator, :all, etc.)
  // See ACCOUNTS_AND_SECRETS.md and apps/mobile/README.md for details.
  "cli": {
    "version": "20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unimatrix-web.fly.dev/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release",
        "credentialsSource": "remote"
        // NOTE: Full iOS production builds (signed for real devices or App Store) require a paid Apple Developer Program membership ($99/year).
        // Without it, use simulator builds (see "preview" profile) or Expo Go for development/testing on iOS.
        // credentialsSource: remote will fail for iOS until you have Apple dev membership + configured credentials.
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://unimatrix-web.fly.dev/api",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        // iOS App Store submission requires paid Apple Developer Program ($99/year) + App Store Connect access.
        // User currently cannot afford the fee, so this is placeholder only. Use for Android only until membership obtained.
        "appleId": "tjpoisal@gmail.com",
        "ascAppId": "6748523981",
        "appleTeamId": "TEAM_ID_PLACEHOLDER"  // TODO: replace with your 10-char Apple Team ID (e.g. from https://developer.apple.com/account/#/membership or eas configure output) AFTER obtaining membership
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "production"
      }
    }
  }
}
