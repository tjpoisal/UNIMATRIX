{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:login": "npx eas-cli@latest login",
    "eas:init": "npx eas-cli@latest init --id a93ce64a-bd02-4777-a432-35f72349253d",
    "build:preview": "npx eas-cli@latest build --profile preview",
    "build:prod": "npx eas-cli@latest build --profile production",
    "build:all": "npx eas-cli@latest build --platform all --profile production",
    "build:android": "npx eas-cli@latest build --platform android --profile production",
    "build:ios": "npx eas-cli@latest build --platform ios --profile production"
  },
  "_note": "IMPORTANT: EAS build commands (and any eas-*) MUST be run with apps/mobile as the current working directory so the correct app.json + eas.json + node_modules are used. Use `pnpm --filter mobile run build:prod` (from monorepo root) or `cd apps/mobile && pnpm run build:prod`. Running npx eas-cli directly from the monorepo root creates wrong root eas.json/app.json and uploads huge incorrect archives (as seen in the failed attempt).",
  "dependencies": {
