{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "eas:login": "npx eas-cli@latest login",
    "eas:init": "npx eas-cli@latest init --id a93ce64a-bd02-4777-a432-35f72349253d",
    "eas:build": "npx eas-cli@latest build",
    "build:preview": "npx eas-cli@latest build --profile preview --no-wait",
    "build:prod": "npx eas-cli@latest build --profile production --no-wait",
    "build:all": "pnpm run build:android && pnpm run build:ios",
    "build:android": "npx eas-cli@latest build --platform android --profile production --no-wait",
    "build:ios": "npx eas-cli@latest build --platform ios --profile preview --no-wait"
  },
  "_note": "IMPORTANT: EAS build commands MUST run with apps/mobile as CWD. From monorepo root use the pnpm aliases: pnpm mobile:build:all (or :ios, :android, :prod, :preview). For extra flags: pnpm --filter mobile exec npx eas-cli@latest build --platform all --profile production --non-interactive. NEVER run raw npx eas-cli from the Unimatrix/ root dir. iOS REAL builds (device/App Store) require $99/yr Apple Developer Program membership (user cannot currently afford). Use :ios alias for free simulator builds (preview profile). Android is fully supported. TEAM_ID_PLACEHOLDER in eas.json only needed if/when obtaining membership.",
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/elements": "^2.9.26",
    "@react-navigation/native": "^7.3.4",
    "@sentry/react-native": "^6.0.0",
    "axios": "^1.18.1",
    "expo": "~56.0.12",
    "expo-background-fetch": "~56.0.19",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.6",
    "posthog-react-native": "^3.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.17",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  },
  "private": true
}
