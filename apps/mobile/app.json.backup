{
  "expo": {
    "name": "Unimatrix",
    "slug": "unimatrix",
    "version": "1.0.0",
    "owner": "tjpoisal",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "unimatrix",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tjpoisal.unimatrix",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "background-fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.tjpoisal.unimatrix",
      "adaptiveIcon": {
        "foreground": "./assets/images/android-icon-foreground.png",
        "background": "./assets/images/android-icon-background.png"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguard": true
          }
        }
      ],
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a93ce64a-bd02-4777-a432-35f72349253d"
      }
    }
  }
}