{
  "manifest_version": 3,
  "name": "Unimatrix — AI Memory for Web LLMs",
  "version": "1.0.0",
  "description": "Persistent AI memory for ChatGPT, Claude, Gemini, Grok, Perplexity, and Copilot. One memory layer for every AI you use.",
  "permissions": [
    "storage",
    "scripting",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://huggingface.co/*",
    "https://x.com/*",
    "https://grok.x.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://deployunimatrix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unimatrix Memory",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://huggingface.co/*",
        "https://x.com/grok*",
        "https://grok.x.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
