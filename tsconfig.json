{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@unimatrix/types": ["packages/types/src"],
      "@unimatrix/api": ["packages/api/src"],
      "@unimatrix/ui": ["packages/ui/src"],
      "@unimatrix/llm": ["packages/llm/src"]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "prisma/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
